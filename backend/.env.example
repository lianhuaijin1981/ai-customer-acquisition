# 应用配置
APP_PORT=8000
APP_ENV=development
APP_JWT_SECRET=your-super-secret-jwt-key-change-in-production
APP_JWT_EXPIRES_IN=7d

# 数据库配置
DATABASE_URL=postgres://postgres:password@localhost:5432/ai_customer_acquisition

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# AI 大模型配置
AI_PROVIDER=kimi
KIMI_API_KEY=your-kimi-api-key-here
KIMI_BASE_URL=https://api.moonshot.cn/v1
OPENAI_API_KEY=
OPENAI_BASE_URL=

# 企业微信配置（私域承接）
WECOM_CORP_ID=
WECOM_APP_SECRET=
WECOM_AGENT_ID=

# 邮件通知配置
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
NOTIFY_EMAIL=

# 日志级别
LOG_LEVEL=debug
