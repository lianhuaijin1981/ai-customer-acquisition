# ===================== 数据库 =====================
DATABASE_URL=postgres://postgres:password@localhost:5432/ai_customer

# ===================== Redis =====================
REDIS_URL=redis://localhost:6379

# ===================== JWT =====================
# ⚠️ 生产环境必须设置！至少 32 字符的随机字符串
# 生成方法: openssl rand -hex 32 或 node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
APP_JWT_SECRET=dev-only-secret-replace-in-production-abc12345
APP_JWT_EXPIRES_IN=7d

# ===================== AI API =====================
# 月之暗面 KIMI API
KIMI_API_KEY=your_kimi_api_key_here
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL=moonshot-v1-8k

# ===================== 应用配置 =====================
APP_PORT=8000
APP_ENV=development
FRONTEND_URL=http://localhost:3100

# ===================== 企业微信 SCRM（可选）=====================
WECOM_CORP_ID=
WECOM_AGENT_ID=
WECOM_SECRET=

# ===================== 数据采集（可选）=====================
WEIBO_COOKIE=
XIAOHONGSHU_COOKIE=
